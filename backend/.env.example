# Forensiq backend environment

# ─── AI brief (provider-agnostic, OpenAI-compatible Chat Completions) ──
# Powers the AI summary in src/ai/brief.ts. Optional: audits still run
# without a key, they just skip the written brief. Defaults target Groq's
# free API. AI_API_KEY falls back to GROQ_API_KEY when unset.
AI_API_KEY=
# GROQ_API_KEY=                  # fallback used only if AI_API_KEY is empty
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_TIMEOUT_MS=45000

# Block explorer API keys (one per chain you want to support)
ETHERSCAN_API_KEY=
OKLINK_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPT_ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# GitHub (optional — boosts rate limit from 60/hr to 5000/hr)
GITHUB_TOKEN=

# Infrastructure (defaults work with docker-compose)
DATABASE_URL=postgres://forensiq:forensiq@localhost:5432/forensiq
REDIS_URL=redis://localhost:6379

# Worker tuning
WORKER_CONCURRENCY=2

# ─── Engine runtime ───────────────────────────────────────────────────
# How analysis engines are executed: "docker" (default) or "kubernetes".
ENGINE_RUNTIME=docker
# Optional cgroup parent for engine/fuzz containers (extra resource isolation).
ENGINE_CGROUP_PARENT=
# Kubernetes runtime only (ENGINE_RUNTIME=kubernetes):
K8S_JOB_NAMESPACE=forensiq
K8S_JOB_SERVICE_ACCOUNT=forensiq-engine-runner

# ─── Runtime / logging ────────────────────────────────────────────────
# NODE_ENV=production switches logs to JSON lines and defaults LOG_LEVEL to info.
NODE_ENV=development
# Log verbosity: debug | info | warn | error (default: debug in dev, info in prod).
LOG_LEVEL=

# Public URL (used in webhook setup instructions, check-run details URLs, share links)
PUBLIC_URL=http://localhost:3000

# GitHub App (for the unified check-run + PR comment experience)
# Register at https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=         # raw PEM or base64-encoded PEM
GITHUB_APP_WEBHOOK_SECRET=

# Email notifications (optional; via SendGrid)
SENDGRID_API_KEY=
NOTIFY_FROM_EMAIL=forensiq@example.com

# ─── Auth (real sessions via GitHub OAuth) ────────────────────────────
# Register an OAuth App at https://github.com/settings/applications/new
# Callback URL must be: ${PUBLIC_URL}/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Session JWT signing key — generate with: openssl rand -hex 32
SESSION_SECRET=

# Frontend origin (for cookie + OAuth bounce). Set explicitly when
# frontend and backend are on different hosts.
FRONTEND_URL=

# ─── S3 archival (optional) ───────────────────────────────────────────
# When set, worker uploads raw tool outputs + report JSON + PDF to S3.
# On EKS, AWS credentials come from IRSA (no AWS_ACCESS_KEY_ID needed).
# For local dev or non-AWS deployments, set the standard AWS env vars.
S3_REPORTS_BUCKET=
AWS_REGION=us-east-1
# Static credentials (local dev / non-AWS). Leave blank on EKS to use IRSA.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# Web-identity / IRSA (set automatically by EKS; only override manually if
# wiring up role assumption outside of an EKS pod).
AWS_WEB_IDENTITY_TOKEN_FILE=
AWS_ROLE_ARN=
